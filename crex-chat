#!/bin/bash
# Crex Sentient CLI Client

if [ -z "$1" ]; then
  echo "Usage: crex-chat 'Your message here'"
  exit 1
fi

MESSAGE="$1"

# Send the message to the background daemon
RESPONSE=$(curl -s -X POST http://127.0.0.1:9090/chat \
     -H "Content-Type: application/json" \
     -d "{\"message\": \"$MESSAGE\"}" | jq -r '.response')

if [ -z "$RESPONSE" ] || [ "$RESPONSE" == "null" ]; then
    echo "[!] The Sentient Daemon is not responding. Is it running?"
    echo "    Start it with: cd ~/crex-daemon && source venv/bin/activate && python3 src/server.py &"
else
    echo -e "\n\033[1;36m[Crex Entity]\033[0m: $RESPONSE\n"
fi
